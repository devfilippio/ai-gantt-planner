# Copy to .env and fill in. .env is gitignored.

# LLM access via OpenRouter (required for the chat agent to use a real model).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: Neon/Postgres connection string. If unset, the app uses an
# in-memory store (fine for local dev; resets on each serverless cold start).
# Provision via the Vercel Marketplace (Neon) and paste the pooled URL here.
DATABASE_URL=

# Optional: set to 1 to run the agent deterministically without any LLM calls
# (used by tests and E2E). Leave unset in production.
# MOCK_LLM=1
